# Copy this file to .env and fill in all values before running the app.
# All variables marked REQUIRED must be set — the app will throw at startup if missing.

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED. SQLite file path for Prisma / LibSQL adapter.
DATABASE_URL="file:./dev.db"

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED. Long random string used to sign JWTs. Minimum 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string"

# RECOMMENDED. Separate secret for CSRF HMAC tokens.
# Falls back to JWT_SECRET if not set — set this to a different value in production.
CSRF_SECRET="change-this-to-a-different-long-random-string"

# ── Internal API ──────────────────────────────────────────────────────────────
# REQUIRED. Token used for server-to-server calls (intake → generate-pdfs).
# WARNING: Must be a strong random value (64+ hex chars). A weak or guessable
# token lets anyone trigger PDF generation for any package, bypassing session auth.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_TOKEN="change-this-to-a-random-string"

# ── DocuSeal (self-hosted e-signature) ───────────────────────────────────────
# Optional. If not set, packages skip straight to "completed" after PDF generation (dev/demo mode).
DOCUSEAL_API_URL="http://your-docuseal-server"
DOCUSEAL_API_TOKEN="your-docuseal-api-token"

# If using DocuSeal webhooks, set this to a shared secret to verify webhook signatures.
DOCUSEAL_WEBHOOK_SECRET=""

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Optional. If not set, emails are logged to the console instead of sent.
#
# Gmail SMTP setup:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail"
#   4. Use your Gmail address as SMTP_USER and the App Password as SMTP_PASS
#
# Other providers (SendGrid, Resend, Mailgun, etc.) also work — just set the
# host, port, user, and password according to your provider's docs.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
FROM_EMAIL="FormFlowNC <your-email@gmail.com>"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
# REQUIRED for correct client link generation in emails.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
